# Minimal Python image for the embedding microservice
FROM python:3.12-slim-bookworm

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY server.py .

EXPOSE 9102

HEALTHCHECK --interval=30s --timeout=15s --retries=3 \
    CMD python3 -c "import urllib.request; urllib.request.urlopen('http://localhost:9102/health')"

CMD ["python3", "server.py"]
